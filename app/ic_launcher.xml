<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Required to make HTTP requests -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DataEngine"
        tools:targetApi="31">
        <activity
            android:name=".activities.SelectTierActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AddSubscriptionActivity"
            android:exported="false" />
        <activity
            android:name=".activities.SubscriptionSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ServiceDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.DashboardActivity"
            android:exported="false" /> <!-- Sign Up screen -->
        <activity
            android:name=".activities.SignupActivity"
            android:exported="false" /> <!-- Login screen -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false" /> <!-- Dashboard or Main Page (placeholder for now) -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true" /> <!-- Welcome screen (LAUNCHER) -->
        <activity
            android:name=".activities.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>